tools/viewer/dist/
tools/viewer/.vite/

# Semantic index (генерируется локально, переиндексируется по mtime)
.semantic-index.sqlite
.semantic-index.sqlite-wal
.semantic-index.sqlite-shm

# SkillOpt metrics
.skillopt-metrics.sqlite
.skillopt-metrics.sqlite-wal
.skillopt-metrics.sqlite-shm

# SkillOpt local overrides (если пользователь не хочет коммитить настройку)
.skillopt.local.json
.env

# Кэш моделей transformers.js (~120 MB)
scripts/semantic/.transformers-cache/

# Рабочая зона: черновики, attachments, dream-reports
.context/

# Сессионная working memory (core.md коммитим, остальное нет)
.remember/now.md
.remember/today.md

# Служебные локи Claude (ScheduleWakeup, hooks)
.claude/scheduled_tasks.lock

# IDE
.vscode/
.idea/
*.swp
